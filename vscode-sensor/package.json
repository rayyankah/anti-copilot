{
  "name": "anti-copilot-sensor",
  "displayName": "Anti-Copilot Sensor",
  "description": "Silently monitors your coding habits and reports them to the Anti-Copilot engine",
  "version": "0.1.0",
  "publisher": "anti-copilot",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antiCopilot.activate",
        "title": "Anti-Copilot: Activate Sensor"
      },
      {
        "command": "antiCopilot.deactivate",
        "title": "Anti-Copilot: Deactivate Sensor"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src/",
    "package": "vsce package"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.0",
    "typescript": "^5.8.0",
    "eslint": "^9.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
