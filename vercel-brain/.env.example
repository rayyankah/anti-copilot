# ─── AWS credentials ───
# NOTE: On Vercel the AWS_* names are RESERVED and cannot be set in the
# dashboard. Use the APP_AWS_* names there. Locally, either set works.
APP_AWS_REGION=us-east-1
APP_AWS_ACCESS_KEY_ID=your_access_key_here
APP_AWS_SECRET_ACCESS_KEY=your_secret_key_here
# APP_AWS_SESSION_TOKEN=    # only if using temporary credentials

# DynamoDB table the brain reads/writes (telemetry, leaderboard, profiles)
DYNAMODB_TABLE_NAME=anti-copilot-telemetry

# ─── Local-dev fallbacks (standard AWS SDK names) ───
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
