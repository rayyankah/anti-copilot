{
  "name": "anti-copilot-desktop-overlay",
  "version": "0.1.0",
  "description": "Transparent frameless overlay that stalks your cursor and demotivates you",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && tsc -p tsconfig.main.json",
    "start": "electron .",
    "lint": "eslint src/"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.0",
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.0",
    "@types/ws": "^8.18.0"
  }
}
