{
  "name": "anti-copilot-desktop-overlay",
  "productName": "Gremlin",
  "version": "0.1.0",
  "description": "Gremlin — a transparent frameless overlay that stalks your cursor and demotivates you",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && tsc -p tsconfig.main.json",
    "start": "electron .",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@giphy/js-fetch-api": "^5.8.0",
    "dotenv": "^17.4.2",
    "electron-is-dev": "^2.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.18.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.0",
    "electron": "^35.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "wait-on": "^8.0.0"
  }
}
